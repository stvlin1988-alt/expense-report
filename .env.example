# .env.example — 複製成 .env 填真值（.env 不進 git）
APP_ENV=development
SECRET_KEY=dev-insecure-key

# OCR（Gemini）
OCR_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# -1=動態思考(lite 讀手寫金額才穩)、0=關閉思考(更省但手寫易錯)
GEMINI_THINKING_BUDGET=-1

# OCR 韌性
GEMINI_MAX_RETRIES=3        # 單輪內對 429/503/5xx/timeout 的重試次數
GEMINI_RETRY_BASE=0.5       # 退避基秒(指數退避 base)
OCR_MAX_ROUNDS=3            # 背景重排輪數上限，達上限收斂成 draft+ocr_failed

# 儲存（Cloudflare R2）
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# 開發專用：一鍵登入捷徑 /dev/login-test + 免相機拍單樣本圖。
# 設 1 才啟用；production（APP_ENV=production）一律無效、路由不註冊。正式部署請留空。
E2E_LOGIN_BYPASS=

# 暫存區/燈號調校（可留預設）
OCR_STALE_SECONDS=120
GREEN_THRESHOLD=0.85
